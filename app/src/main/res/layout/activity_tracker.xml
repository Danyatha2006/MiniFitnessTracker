<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="120dp">

        <!-- Main Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activity Tracker"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track your daily movement"
            android:textColor="#7D8590"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp" />

        <!-- Glass Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_green"
            android:padding="24dp">

            <!-- Shoe Icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👟"
                android:textSize="34sp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Steps -->
            <TextView
                android:id="@+id/stepsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Steps: 0"
                android:textColor="#39FF14"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp" />

            <!-- Pause Button -->
            <Button
                android:id="@+id/pauseBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Pause Tracking"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/green_button"
                android:layout_marginBottom="14dp" />

            <!-- Calories Button -->
            <Button
                android:id="@+id/caloriesBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Calculate Calories"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary"
                android:layout_marginBottom="14dp" />

            <!-- Back Button -->
            <Button
                android:id="@+id/backBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Back"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>