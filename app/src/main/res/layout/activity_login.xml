<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <!-- Login Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Main Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/glass_card_green">

            <!-- Logo -->
            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#39FF14"
                android:layout_marginBottom="18dp" />

            <!-- Welcome -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_gravity="center" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login to continue your fitness journey"
                android:textColor="#9AA4AF"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="28dp" />

            <!-- Email -->
            <EditText
                android:id="@+id/email"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter your email"
                android:textColor="#FFFFFF"
                android:textColorHint="#B0B0B0"
                android:background="@drawable/input_field"
                android:padding="16dp"
                android:layout_marginBottom="18dp" />

            <!-- Password -->
            <EditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter your password"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#B0B0B0"
                android:background="@drawable/input_field"
                android:padding="16dp" />

            <!-- Forgot Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password?"
                android:textColor="#39FF14"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp" />

            <!-- Login Button -->
            <Button
                android:id="@+id/loginBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Login"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="17sp"
                android:background="@drawable/green_button"
                android:layout_marginBottom="20dp" />

            <!-- OR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="or"
                android:textColor="#7D8590"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Signup Button -->
            <Button
                android:id="@+id/signupBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Create New Account"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_primary" />

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay healthy, stay strong!"
                android:textColor="#7D8590"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginTop="28dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>