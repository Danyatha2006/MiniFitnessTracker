<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="60dp">

        <TextView
            android:id="@+id/welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello 👋"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keep pushing your limits!"
            android:textColor="#7D8590"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_green"
            android:padding="24dp"
            android:elevation="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Main Features"
                android:textColor="#39FF14"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnChatbot"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="AI Fitness Buddy 🤖"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnTracker"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Track Activity 🔥"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnWater"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Water Intake 💧"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnBMI"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="BMI Calculator ⚖️"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnSleepCalc"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Sleep Calculator 😴"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnDiet"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Diet Plan 🍎"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnMeditation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Meditation 🧘"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnSleepTracker"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Sleep Tracker 🌙"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Profile 👤"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnHistory"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="History 📊"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Settings ⚙️"
                android:textAllCaps="false"
                android:backgroundTint="#39FF14"
                android:textColor="#000000" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>