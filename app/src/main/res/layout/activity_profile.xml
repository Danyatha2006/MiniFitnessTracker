<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="120dp">

        <TextView
            android:text="Profile 👤"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Your account details"
            android:textColor="#9A9AB8"
            android:textSize="14sp"
            android:layout_marginBottom="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:background="#1A1A2E"
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/name"
                android:text="User Name"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/username"
                android:text="username"
                android:textColor="#B0B0D0"
                android:textSize="16sp"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/bio"
                android:text="Your bio"
                android:textColor="#9A9AB8"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/editBtn"
                android:text="Edit Profile ✏️"
                android:textColor="#FFFFFF"
                android:background="#6A5AE0"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="55dp"/>

            <Button
                android:id="@+id/logout"
                android:text="Logout 🚪"
                android:textColor="#FFFFFF"
                android:background="#6A5AE0"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="55dp"/>

            <Button
                android:id="@+id/backBtn"
                android:text="← Back to Dashboard"
                android:textColor="#FFFFFF"
                android:background="#2A2A3D"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>