<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile 👤"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage your account details"
            android:textColor="#7D8590"
            android:textSize="15sp"
            android:layout_marginBottom="30dp" />

        <!-- Main Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/glass_card_green">

            <!-- Profile Image -->
            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher_round"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:background="@drawable/profile_circle_bg"
                android:padding="2dp" />

            <!-- Upload Button -->
            <Button
                android:id="@+id/btnUpload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Photo"
                android:textAllCaps="false"
                android:layout_gravity="center"
                android:layout_marginTop="18dp"
                android:textColor="#000000"
                android:backgroundTint="#39FF14" />

            <!-- Username -->
            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Username"
                android:textColor="#FFFFFF"
                android:textColorHint="#7D8590"
                android:backgroundTint="#39FF14"
                android:layout_marginTop="28dp" />

            <!-- Bio -->
            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:hint="Bio"
                android:textColor="#FFFFFF"
                android:textColorHint="#7D8590"
                android:backgroundTint="#39FF14"
                android:layout_marginTop="18dp" />

            <!-- Email -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:textColor="#FFFFFF"
                android:textColorHint="#7D8590"
                android:backgroundTint="#39FF14"
                android:layout_marginTop="18dp" />

            <!-- Weight -->
            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Weight (kg)"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#7D8590"
                android:backgroundTint="#39FF14"
                android:layout_marginTop="18dp" />

            <!-- Height -->
            <EditText
                android:id="@+id/etHeight"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Height (cm)"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#7D8590"
                android:backgroundTint="#39FF14"
                android:layout_marginTop="18dp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Save Profile 💾"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1F2B"
                android:layout_marginTop="30dp" />

            <!-- Edit Button -->
            <Button
                android:id="@+id/btnEdit"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Edit Profile ✏️"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1F2B"
                android:layout_marginTop="16dp" />

            <!-- Back Button -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Back ⬅️"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1F2B"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>