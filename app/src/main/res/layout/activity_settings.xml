<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="80dp"
        android:paddingBottom="30dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings ⚙️"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage your app preferences"
            android:textColor="#7D8590"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- Settings Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_green"
            android:padding="22dp"
            android:elevation="8dp">

            <!-- Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Controls"
                android:textColor="#39FF14"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="18dp" />

            <!-- Reset Button -->
            <Button
                android:id="@+id/resetBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Reset All Data ♻️"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:background="@drawable/green_button"
                android:layout_marginBottom="18dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E2A33"
                android:layout_marginBottom="18dp"/>

            <!-- Back Button -->
            <Button
                android:id="@+id/backBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="← Back to Dashboard"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:background="@drawable/btn_primary" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>