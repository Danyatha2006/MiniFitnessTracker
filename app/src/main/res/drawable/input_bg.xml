<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 🔥 When field is focused -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#1E1E30"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="2dp"
                android:color="#6C63FF"/>
        </shape>
    </item>

    <!-- 🔹 Default state -->
    <item>
        <shape>
            <solid android:color="#1C1C2E"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="1dp"
                android:color="#2E2E4D"/>
        </shape>
    </item>

</selector>